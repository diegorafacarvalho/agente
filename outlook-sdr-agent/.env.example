# Microsoft Graph API (Outlook)
OUTLOOK_CLIENT_ID=seu_client_id_aqui
OUTLOOK_CLIENT_SECRET=seu_client_secret_aqui
OUTLOOK_TENANT_ID=seu_tenant_id_aqui
OUTLOOK_EMAIL=seu_email@outlook.com

# IA - Google Gemini (GRÁTIS - RECOMENDADO)
# Obtenha sua chave em: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=sua_chave_gemini_aqui
GOOGLE_MODEL=gemini-pro

# IA - OpenAI (PAGO - opcional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4

# IA - Ollama (GRÁTIS - local, opcional)
# OLLAMA_MODEL=llama2
# OLLAMA_BASE_URL=http://localhost:11434

# Configurações de Follow-up
FOLLOWUP_INITIAL_HOURS=24
FOLLOWUP_SECOND_HOURS=72
FOLLOWUP_MAX_ATTEMPTS=3

# Configurações de Agendamento
MEETING_DURATION_MINUTES=30
WORKING_HOURS_START=9
WORKING_HOURS_END=18

# Banco de Dados
DATABASE_URL=sqlite:///data/sdr_agent.db

# Logs
LOG_LEVEL=INFO
LOG_FILE=logs/sdr_agent.log
